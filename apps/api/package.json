{
  "name": "@sammo-ts/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/main.ts --format esm --dts",
    "dev": "tsup src/main.ts --format esm --watch --onSuccess \"node dist/main.js\"",
    "start": "node dist/main.js",
    "test": "vitest run",
    "typeorm": "typeorm-ts-node-commonjs",
    "db:migrate": "npm run typeorm migration:run -- -d src/data-source.ts",
    "db:revert": "npm run typeorm migration:revert -- -d src/data-source.ts",
    "db:create-migration": "npm run typeorm migration:create"
  },
  "dependencies": {
    "@sammo-ts/common": "workspace:*",
    "@sammo-ts/infra": "workspace:*",
    "@sammo-ts/logic": "workspace:*",
    "@sammo-ts/engine": "workspace:*",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@trpc/server": "^10.45.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}