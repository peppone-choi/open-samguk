# Game Configuration for Legacy Game Server
# Based on: https://storage.hided.net/gitea/devsam/docker/hidche/game.orig.env
#
# Configure game server settings here.

# Git Repository for Game Code
# Use ssh:// format if using SSH keys (configure in php-fpm container)
gameGitPath=
# Example (ssh): ssh://git@github.com/your-org/your-game-repo.git
gameGitBranch=main
imgGitPath=
# Example (ssh): ssh://git@github.com/your-org/your-image-repo.git

# Timezone
TZ=Asia/Seoul
LC_ALL=C.UTF-8

# Server List (comma-separated server codes)
# These correspond to game server instances
HIDCHE_SERVER_LIST=che,kwe,pwe,twe,nya,pya,hwe

# External Access URL (REQUIRED)
# This must be the publicly accessible URL for the game
# Include the full path (e.g., http://yourdomain.com/sam)
HIDCHE_GAME_PATH=http://localhost:8080

# Image Serving Configuration
# yes = serve images from game server
# no = use external CDN/image server
HIDCHE_IMAGE_USE_INTERNAL=yes

# Image Path
# If HIDCHE_IMAGE_USE_INTERNAL=yes: relative path from HIDCHE_GAME_PATH
# If HIDCHE_IMAGE_USE_INTERNAL=no: full URL to image server
HIDCHE_IMAGE_PATH=../image

# Board Files Path (optional, for Rhymix integration)
# HIDCHE_BOARD_FILES_PATH=/var/www/board/files
