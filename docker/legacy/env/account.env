# Account Configuration for Legacy Game Server
# Template based on upstream hidche docker env
#
# IMPORTANT: Copy this file and fill in your own values!
# DO NOT commit sensitive values to version control.

# MariaDB Root Password (REQUIRED)
MARIADB_ROOT_PASSWORD=change_this_root_password

# MariaDB Root Access Host (optional, use % for external access)
MARIADB_ROOT_HOST=

# Password Salt for User Passwords (REQUIRED - make it long and random!)
HIDCHE_PW_SALT=your_very_long_and_random_salt_here_at_least_32_chars

# Database Prefix
HIDCHE_DB_PREFIX=hidche

# Board Database Credentials (for Rhymix/XE board integration)
HIDCHE_DB_BBS_USER=board
HIDCHE_DB_BBS_PASSWORD=board_password_here

# Image Sync Key (16+ characters, leave blank for random)
HIDCHE_IMAGE_REQUEST_KEY=

# Admin Account Credentials (REQUIRED)
HIDCHE_ADMIN=admin
HIDCHE_PASSWORD=admin_password_here

# Kakao OAuth API Keys (optional - for Kakao login)
# Get these from https://developers.kakao.com/
HIDCHE_KAKAO_REST_KEY=
HIDCHE_KAKAO_ADMIN_KEY=
