{
  "name": "open-samguk",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "pnpm --filter @sammo-ts/api dev",
    "dev:web": "pnpm --filter @sammo-ts/web dev",
    "dev:engine": "pnpm --filter @sammo-ts/engine dev",
    "build": "pnpm -r build",
    "build:api": "pnpm --filter @sammo-ts/api build",
    "build:web": "pnpm --filter @sammo-ts/web build",
    "db:migrate": "pnpm --filter @sammo-ts/api db:migrate",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "sqlite3",
      "esbuild",
      "@swc/core"
    ],
    "ignoredBuiltDependencies": [
      "@nestjs/core",
      "bcrypt",
      "sharp",
      "sqlite3"
    ]
  }
}
