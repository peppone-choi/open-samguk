{
  "name": "sammo-ts",
  "version": "0.0.1",
  "private": true,
  "description": "삼국지 모의전투 HiDCHe - TypeScript 리라이트",
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "dev:api": "pnpm --filter @sammo/api start:dev",
    "dev:engine": "pnpm --filter @sammo/engine dev",
    "dev:web": "pnpm --filter @sammo/web dev",
    "db:generate": "pnpm --filter @sammo/infra db:generate",
    "db:migrate": "pnpm --filter @sammo/infra db:migrate",
    "db:push": "pnpm --filter @sammo/infra db:push",
    "setup": "tsx scripts/setup.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.10.0",
    "eslint": "^9.0.0",
    "prettier": "^3.2.0",
    "tsdown": "^0.2.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}