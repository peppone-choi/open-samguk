{
  "permissions": {
    "allow": [
      "Bash(pnpm:*)",
      "Bash(git:*)",
      "Bash(docker compose:*)",
      "Bash(node:*)",
      "Bash(npx:*)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep"
    ]
  },
  "hooks": {
    "PreToolUse": [],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write \"$FILE_PATH\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolUseFailure": [],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude needs attention\" with title \"Claude Code\"'"
          }
        ]
      }
    ],
    "UserPromptSubmit": [],
    "SessionStart": [],
    "SessionEnd": [],
    "Stop": [],
    "SubagentStart": [],
    "SubagentStop": [],
    "PreCompact": [],
    "PermissionRequest": []
  }
}
