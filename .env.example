# Database Connection
# PostgreSQL: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sammo?schema=public"

# Redis Connection
REDIS_URL="redis://localhost:6379"

# Security
JWT_SECRET="your-super-secret-key-change-it"

# Server Ports
GAME_PORT=4000
WEB_PORT=3000
ENGINE_PORT=4002

# Frontend Configuration (Next.js)
# This URL must match the API server's address and port
NEXT_PUBLIC_API_URL="http://localhost:4000/trpc"

# Image Server URL (game assets)
# Default uses JSDelivr CDN from GitHub repo
NEXT_PUBLIC_IMAGE_URL="https://cdn.jsdelivr.net/gh/peppone-choi/samguk-image@master"

# Kakao OAuth (optional)
KAKAO_REST_KEY=""
KAKAO_ENABLED="false"
