{
  "name": "@sammo/common",
  "version": "0.0.1",
  "description": "공용 유틸리티 - RNG, JosaUtil, 타입 정의",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm && tsc --emitDeclarationOnly --declaration --outDir dist",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --dir .",
    "test:watch": "vitest --dir ."
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "tsdown": "^0.2.0",
    "vitest": "^2.1.0"
  },
  "files": [
    "dist"
  ]
}
