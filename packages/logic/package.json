{
  "name": "@sammo/logic",
  "version": "0.0.1",
  "description": "순수 게임 로직 - 엔티티, 액션, 상태 관리",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm && tsc --emitDeclarationOnly --declaration --outDir dist",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sammo/common": "workspace:*",
    "@sammo/infra": "workspace:*",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "tsdown": "^0.2.0",
    "typescript": "^5.3.3"
  },
  "files": [
    "dist"
  ]
}
