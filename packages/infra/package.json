{
  "name": "@sammo/infra",
  "version": "0.0.1",
  "description": "인프라 - Prisma, Redis, 환경 검증",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "postinstall": "prisma generate",
    "build": "prisma generate && tsdown src/index.ts --format esm && tsc --emitDeclarationOnly --declaration --outDir dist",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "ioredis": "^5.4.0",
    "prisma": "^5.22.0"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "tsdown": "^0.2.0"
  },
  "files": [
    "dist",
    "prisma"
  ]
}